---
import config from 'virtual:starlight/user-config';
import { Icon } from '@astrojs/starlight/components';

const links = config.social || [];
const github = links.find(({ href }) => href?.includes('github.com'));
const nonGithubLinks = links.filter(({ href }) => !href?.includes('github.com'));

function parseGitHubRepo(url) {
  try {
    const { pathname } = new URL(url);
    const [owner, repo] = pathname.replace(/^\/+/, '').split('/');
    if (!owner || !repo) return null;
    return `${owner}/${repo}`;
  } catch {
    return null;
  }
}

const repo = github ? parseGitHubRepo(github.href) : null;
let starsCount = null;
let forksCount = null;

function formatCount(count) {
  if (count === null || count === undefined) return null;
  if (count >= 1000000) return `${(count / 1000000).toFixed(1).replace(/\.0$/, '')}M`;
  if (count >= 1000) return `${(count / 1000).toFixed(1).replace(/\.0$/, '')}k`;
  return String(count);
}

if (repo) {
  try {
    const response = await fetch(`https://api.github.com/repos/${repo}`, {
      headers: {
        Accept: 'application/vnd.github+json',
      },
    });

    if (response.ok) {
      const data = await response.json();
      starsCount = formatCount(data.stargazers_count);
      forksCount = formatCount(data.forks_count);
    }
  } catch {
    // Keep navbar stable if GitHub API is unavailable.
  }
}
---

{
  links.length > 0 && (
    <div class="social-wrap">
      {nonGithubLinks.map(({ label, href, icon }) => (
        <a href={href} rel="me" class="social-link sl-flex">
          <span class="sr-only">{label}</span>
          <Icon name={icon} />
        </a>
      ))}

      {
        repo && starsCount && forksCount && (
          <a class="gh-pill" href={github.href} rel="noopener noreferrer" target="_blank" aria-label="GitHub repository stars and forks">
            <Icon name="github" />

            <span class="stat-chip" title="Stars">
              <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path fill="currentColor" d="M12 17.27L18.18 21 16.54 13.97 22 9.24 14.81 8.63 12 2 9.19 8.63 2 9.24 7.46 13.97 5.82 21z" />
              </svg>
              <span class="stat-value">{starsCount}</span>
            </span>

            <span class="stat-chip" title="Forks">
              <svg class="stat-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path fill="currentColor" d="M7 3a3 3 0 0 0-1 5.83V15a5 5 0 0 0 5 5h2.17a3 3 0 1 0 0-2H11a3 3 0 0 1-3-3V8.83A3 3 0 1 0 7 3zm0 2a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm9 0a3 3 0 0 0-1 5.83V15a3 3 0 1 0 2 0v-4.17A3 3 0 0 0 16 5zm0 2a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm0 12a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
              </svg>
              <span class="stat-value">{forksCount}</span>
            </span>
          </a>
        )
      }
    </div>
  )
}

<style is:global>
  .social-wrap {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .social-link {
    color: var(--sl-color-text-accent);
    padding: 0.5em;
    margin: -0.5em;
  }

  .social-link:hover {
    color: var(--sl-color-accent-high);
  }

  .gh-pill {
    display: none;
    color: var(--sl-color-accent) !important;
    align-items: center;
    gap: 0.45rem;
    margin-left: 0.25rem;
    height: 1.7rem;
    padding: 0 0.5rem 0 0.45rem;
    border-radius: 999px;
    background: rgba(255, 81, 0, 0.14);
    border: none;
    text-decoration: none !important;
    transition: background-color 0.18s ease, transform 0.18s ease;
    line-height: 1;
  }

  .gh-pill:hover {
    background: rgba(255, 81, 0, 0.14);
    transform: none;
  }

  .gh-pill :global(svg[data-icon='github']) {
    width: 1rem;
    height: 1rem;
    color: var(--sl-color-text-accent);
  }

  .stat-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.24rem;
    padding: 0.18rem 0.36rem;
    border-radius: 999px;
    background: rgba(255, 81, 0, 0.2);
    border: none;
  }

  .stat-icon {
    width: 0.82rem;
    height: 0.82rem;
    min-width: 0.82rem;
    display: block;
    color: var(--sl-color-accent-high);
    fill: currentColor;
    opacity: 1;
  }

  .stat-value {
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--sl-color-accent-high);
  }

  @media (min-width: 72rem) {
    .gh-pill {
      display: inline-flex;
    }
  }
</style>
